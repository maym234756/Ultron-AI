{
  "name": "astra",
  "private": true,
  "version": "0.0.2",
  "description": "A local AI desktop assistant powered by Ollama.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"npm:server:dev\" \"npm:web:dev\"",
    "web:dev": "vite",
    "server:dev": "npm run db:generate && tsx watch server/index.ts",
    "build:web": "tsc -p tsconfig.app.json && vite build",
    "build": "npm run db:generate && tsc -b && vite build && tsc -p tsconfig.server.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "desktop:build": "npm run build && npm run build:electron",
    "desktop:dist": "node scripts/build-desktop.mjs",
    "desktop:pack": "npm run desktop:build && electron-builder --win dir --x64",
    "db:generate": "npm run db:generate:sqlite && npm run db:generate:postgres",
    "db:generate:sqlite": "prisma generate --schema prisma/schema.prisma",
    "db:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:push": "set DATABASE_URL=file:./astra.db&& prisma db push --schema prisma/schema.prisma --skip-generate",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgres.prisma --skip-generate",
    "db:studio": "set DATABASE_URL=file:./astra.db&& prisma studio --schema prisma/schema.prisma",
    "db:studio:postgres": "prisma studio --schema prisma/schema.postgres.prisma",
    "db:postgres:up": "docker compose -f docker-compose.postgres.yml up -d --wait",
    "db:postgres:down": "docker compose -f docker-compose.postgres.yml down",
    "db:postgres:reset": "docker compose -f docker-compose.postgres.yml down -v",
    "db:postgres:logs": "docker compose -f docker-compose.postgres.yml logs -f postgres",
    "db:mail:logs": "docker compose -f docker-compose.postgres.yml logs -f mailpit",
    "test:router": "tsx scripts/router-eval.ts",
    "test:astra": "tsx scripts/astra-eval.ts",
    "lint": "oxlint",
    "preview": "vite preview",
    "start": "node dist-server/index.js",
    "tray": "electron electron/main.ts",
    "tray:dev": "concurrently -k -n api,web,tray -c cyan,green,yellow \"npm:server:dev\" \"npm:web:dev\" \"sleep 4 && electron electron/main.ts\""
  },
  "build": {
    "appId": "com.astra.localassistant",
    "productName": "Astra",
    "asar": true,
    "directories": {
      "output": "desktop-release"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "dist-electron/**/*",
      "prisma/generated/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Astra-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@types/katex": "^0.16.8",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.22.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "prisma": "^6.19.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}

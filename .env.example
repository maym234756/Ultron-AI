# Local desktop default
DATABASE_URL="file:./ultron.db"
# Production example
# DATABASE_URL="postgresql://ultron:change-me@localhost:5432/ultron?schema=public"

# Cookie/session auth
APP_ORIGIN="http://localhost:5173"
AUTH_SESSION_COOKIE="ultron_session"
AUTH_COOKIE_SAME_SITE="lax"
# AUTH_COOKIE_SECURE="1"
# AUTH_COOKIE_DOMAIN="example.com"
AUTH_EMAIL_VERIFICATION_MINUTES="30"
AUTH_PASSWORD_RESET_MINUTES="30"
ORGANIZATION_INVITE_DAYS="7"
# AUTH_CHALLENGE_DELIVERY="auto"
# AUTH_SMTP_HOST="127.0.0.1"
# AUTH_SMTP_PORT="1025"
# AUTH_SMTP_SECURE="0"
# AUTH_MAIL_FROM="Ultron <no-reply@ultron.local>"

# Stable encryption key for deployed credential vault data
# CREDENTIAL_ENCRYPTION_KEY="replace-with-a-long-random-secret"

# Self-hosted Postgres defaults for docker-compose.postgres.yml
# ULTRON_POSTGRES_USER="ultron"
# ULTRON_POSTGRES_PASSWORD="ultron_dev_password"
# ULTRON_POSTGRES_DB="ultron"
# ULTRON_POSTGRES_PORT="5432"
# ULTRON_ADMINER_PORT="8088"
# ULTRON_MAILPIT_SMTP_PORT="1025"
# ULTRON_MAILPIT_UI_PORT="8025"

PORT=8787
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# Local desktop default
DATABASE_URL="file:./astra.db"
# Production example
# DATABASE_URL="postgresql://astra:change-me@localhost:5432/astra?schema=public"

# Cookie/session auth
APP_ORIGIN="http://localhost:5173"
VITE_API_BASE_URL="http://localhost:8787"
AUTH_SESSION_COOKIE="astra_session"
AUTH_COOKIE_SAME_SITE="lax"
# AUTH_COOKIE_SECURE="1"
# AUTH_COOKIE_DOMAIN="example.com"
AUTH_EMAIL_VERIFICATION_MINUTES="30"
AUTH_PASSWORD_RESET_MINUTES="30"
ORGANIZATION_INVITE_DAYS="7"
# AUTH_CHALLENGE_DELIVERY="auto"
# AUTH_SMTP_HOST="127.0.0.1"
# AUTH_SMTP_PORT="1025"
# AUTH_SMTP_SECURE="0"
# AUTH_MAIL_FROM="Astra <no-reply@astra.local>"

# Stable encryption key for deployed credential vault data
# CREDENTIAL_ENCRYPTION_KEY="replace-with-a-long-random-secret"

# Self-hosted Postgres defaults for docker-compose.postgres.yml
# ASTRA_POSTGRES_USER="astra"
# ASTRA_POSTGRES_PASSWORD="astra_dev_password"
# ASTRA_POSTGRES_DB="astra"
# ASTRA_POSTGRES_PORT="5432"
# ASTRA_ADMINER_PORT="8088"
# ASTRA_MAILPIT_SMTP_PORT="1025"
# ASTRA_MAILPIT_UI_PORT="8025"

PORT=8787
MODEL_PROVIDER=ollama
MODEL_NAME=llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Hosted OpenAI-compatible model provider example
# MODEL_PROVIDER=openai-compatible
# MODEL_API_BASE_URL=https://api.openai.com/v1
# MODEL_API_KEY=replace-me
# MODEL_NAME=gpt-4o-mini
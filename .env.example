# Local development defaults.
# Copy this file to .env and keep Ollama enabled for local testing.
DATABASE_URL="file:./lumivex.db"
# Production example
# DATABASE_URL="postgresql://lumivex:change-me@localhost:5432/lumivex?schema=public"

# Cookie/session auth
APP_ORIGIN="http://localhost:5173"
VITE_API_BASE_URL="http://localhost:8787"
AUTH_SESSION_COOKIE="lumivex_session"
AUTH_COOKIE_SAME_SITE="lax"
# AUTH_COOKIE_SECURE="1"
# AUTH_COOKIE_DOMAIN="example.com"
AUTH_EMAIL_VERIFICATION_MINUTES="30"
AUTH_PASSWORD_RESET_MINUTES="30"
ORGANIZATION_INVITE_DAYS="7"
# AUTH_CHALLENGE_DELIVERY="auto"
# AUTH_SMTP_HOST="127.0.0.1"
# AUTH_SMTP_PORT="1025"
# AUTH_SMTP_SECURE="0"
# AUTH_SMTP_USER=""
# AUTH_SMTP_PASS=""
# AUTH_MAIL_FROM="Lumivex AI <no-reply@lumivex.local>"

# Stable encryption key for deployed credential vault data
# CREDENTIAL_ENCRYPTION_KEY="replace-with-a-long-random-secret"

# Self-hosted Postgres defaults for docker-compose.postgres.yml
# LUMIVEX_POSTGRES_USER="lumivex"
# LUMIVEX_POSTGRES_PASSWORD="lumivex_dev_password"
# LUMIVEX_POSTGRES_DB="lumivex"
# LUMIVEX_POSTGRES_PORT="5432"
# LUMIVEX_ADMINER_PORT="8088"
# LUMIVEX_MAILPIT_SMTP_PORT="1025"
# LUMIVEX_MAILPIT_UI_PORT="8025"

PORT=8787
MODEL_PROVIDER=ollama
MODEL_NAME=llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Hosted OpenAI-compatible model provider example.
# Useful for local parity checks against production, but do not commit real keys.
# MODEL_PROVIDER=openai-compatible
# MODEL_API_BASE_URL=https://api.openai.com/v1
# MODEL_API_KEY=replace-me
# MODEL_NAME=gpt-4o-mini

# Stripe billing. Create monthly recurring prices in Stripe and paste only the price IDs here.
# STRIPE_SECRET_KEY=sk_test_replace-me
# STRIPE_WEBHOOK_SECRET=whsec_replace-me
# STRIPE_PRICE_STARTER=price_replace-me
# STRIPE_PRICE_PRO=price_replace-me
# STRIPE_PRICE_BUSINESS=price_replace-me
# STRIPE_APP_ORIGIN=http://localhost:5173
# STRIPE_SUCCESS_URL=http://localhost:5173/?billing=success
# STRIPE_CANCEL_URL=http://localhost:5173/?billing=cancelled
# STRIPE_PORTAL_RETURN_URL=http://localhost:5173
# OPENAI_INPUT_USD_PER_1M=0.15
# OPENAI_OUTPUT_USD_PER_1M=0.60
# BILLING_USAGE_MARKUP=4
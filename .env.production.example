# Production backend
NODE_ENV="production"
PORT="8787"
APP_ORIGIN="https://astra-one-red.vercel.app"

# Frontend build-time backend URL. Set this in Vercel after the backend deploys.
VITE_API_BASE_URL="https://api.your-astra-domain.com"

# Production database. Render injects this from the managed Postgres database.
DATABASE_URL="postgresql://astra:replace-me@db.example.com:5432/astra?schema=public"

# Cross-origin auth cookies for Vercel frontend + hosted backend.
AUTH_SESSION_COOKIE="astra_session"
AUTH_COOKIE_SAME_SITE="none"
AUTH_COOKIE_SECURE="1"
# AUTH_COOKIE_DOMAIN=".your-astra-domain.com"

# Use a long stable value before saving production credential-vault data.
CREDENTIAL_ENCRYPTION_KEY="replace-with-a-long-random-secret"

# Start with debug for first deploy smoke tests, then switch to smtp for public beta.
AUTH_CHALLENGE_DELIVERY="smtp"
AUTH_SMTP_HOST="smtp.example.com"
AUTH_SMTP_PORT="587"
AUTH_SMTP_SECURE="0"
AUTH_SMTP_USER="replace-me"
AUTH_SMTP_PASS="replace-me"
AUTH_MAIL_FROM="Astra <no-reply@your-astra-domain.com>"

# Backend-reachable model runtime. Render does not host local Ollama automatically.
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="llama3.2"NODE_ENV="production"
PORT="8787"

# Public frontend URL. Add every deployed frontend origin, comma-separated.
APP_ORIGIN="https://astra-one-red.vercel.app"

# Frontend-only Vercel variable. Set this in Vercel to the public backend URL.
VITE_API_BASE_URL="https://api.your-astra-domain.com"

# Production database. Use hosted Postgres for public deployments.
DATABASE_URL="postgresql://astra:replace-me@db.example.com:5432/astra?schema=public"

# Cross-origin frontend/backend cookies require SameSite=None and Secure=1.
AUTH_SESSION_COOKIE="astra_session"
AUTH_COOKIE_SAME_SITE="none"
AUTH_COOKIE_SECURE="1"
# AUTH_COOKIE_DOMAIN="your-astra-domain.com"
AUTH_EMAIL_VERIFICATION_MINUTES="30"
AUTH_PASSWORD_RESET_MINUTES="30"
ORGANIZATION_INVITE_DAYS="7"

# Use a stable long random value before storing production credentials.
CREDENTIAL_ENCRYPTION_KEY="replace-with-a-long-random-secret"

# Auth email delivery. Use a real SMTP provider for public accounts.
AUTH_CHALLENGE_DELIVERY="smtp"
AUTH_SMTP_HOST="smtp.example.com"
AUTH_SMTP_PORT="587"
AUTH_SMTP_SECURE="0"
AUTH_SMTP_USER="replace-me"
AUTH_SMTP_PASS="replace-me"
AUTH_MAIL_FROM="Astra <no-reply@your-astra-domain.com>"

# Model runtime. For a public backend, point at a reachable Ollama or compatible internal runtime.
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="llama3.2"
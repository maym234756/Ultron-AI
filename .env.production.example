# Production backend
NODE_ENV="production"
PORT="8787"

# Public frontend URL. Add every deployed frontend origin, comma-separated.
APP_ORIGIN="https://astra-one-red.vercel.app,https://lumivexai.com,https://www.lumivexai.com"

# Frontend-only Vercel variable. Set this in Vercel to the public backend URL.
VITE_API_BASE_URL="https://api.your-lumivexai-domain.com"

# Production database. Use hosted Postgres for public deployments.
DATABASE_URL="postgresql://lumivex:replace-me@db.example.com:5432/lumivex?schema=public"

# Cross-origin frontend/backend cookies require SameSite=None and Secure=1.
AUTH_SESSION_COOKIE="lumivex_session"
AUTH_COOKIE_SAME_SITE="none"
AUTH_COOKIE_SECURE="1"
# AUTH_COOKIE_DOMAIN="your-lumivexai-domain.com"
AUTH_EMAIL_VERIFICATION_MINUTES="30"
AUTH_PASSWORD_RESET_MINUTES="30"
ORGANIZATION_INVITE_DAYS="7"

# Use a stable long random value before storing production credentials.
CREDENTIAL_ENCRYPTION_KEY="replace-with-a-long-random-secret"

# Auth email delivery. Use a real SMTP provider for public accounts.
AUTH_CHALLENGE_DELIVERY="smtp"
AUTH_SMTP_HOST="smtp.example.com"
AUTH_SMTP_PORT="587"
AUTH_SMTP_SECURE="0"
AUTH_SMTP_USER="replace-me"
AUTH_SMTP_PASS="replace-me"
AUTH_MAIL_FROM="Lumivex AI <no-reply@your-lumivexai-domain.com>"

# Model runtime for the deployed backend.
# Public deployments should usually use a hosted OpenAI-compatible provider.
MODEL_PROVIDER="openai-compatible"
MODEL_API_BASE_URL="https://api.openai.com/v1"
MODEL_API_KEY="replace-me"
MODEL_NAME="gpt-4o-mini"

# Self-hosted Ollama alternative for a backend that can actually reach the Ollama host.
# MODEL_PROVIDER="ollama"
# OLLAMA_BASE_URL="http://127.0.0.1:11434"
# OLLAMA_MODEL="llama3.2"

# Stripe subscriptions and hosted model usage accounting.
STRIPE_SECRET_KEY="sk_live_replace-me"
STRIPE_WEBHOOK_SECRET="whsec_replace-me"
STRIPE_PRICE_STARTER="price_replace-me"
STRIPE_PRICE_PRO="price_replace-me"
STRIPE_PRICE_BUSINESS="price_replace-me"
STRIPE_APP_ORIGIN="https://lumivexai.com"
STRIPE_SUCCESS_URL="https://lumivexai.com/?billing=success"
STRIPE_CANCEL_URL="https://lumivexai.com/?billing=cancelled"
STRIPE_PORTAL_RETURN_URL="https://lumivexai.com"
OPENAI_INPUT_USD_PER_1M="0.15"
OPENAI_OUTPUT_USD_PER_1M="0.60"
BILLING_USAGE_MARKUP="4"